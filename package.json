{
  "name": "business-credit-system-enhancement-case-study",
  "version": "3.0.0",
  "description": "A senior banking BA portfolio case for evidence-grounded credit memo generation, rule governance, data lineage, value realization, and release assurance.",
  "private": false,
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "scripts": {
    "build": "next build",
    "check": "pnpm run check:security && pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build",
    "check:security": "node scripts/check-security.mjs",
    "dev": "next dev --hostname 127.0.0.1",
    "lint": "eslint . --max-warnings=0",
    "start": "next start --hostname 127.0.0.1",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "business-analyst",
    "banking",
    "credit-risk",
    "commercial-lending",
    "loan-origination",
    "document-automation",
    "document-checklist",
    "credit-memo",
    "business-rules",
    "rule-governance",
    "data-lineage",
    "data-quality",
    "benefits-realization",
    "product-owner",
    "release-readiness",
    "traceability",
    "approval-routing",
    "policy-exceptions",
    "uat",
    "portfolio",
    "nextjs"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "clsx": "2.1.1",
    "lucide-react": "1.23.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "recharts": "3.9.1",
    "tailwind-merge": "3.6.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@playwright/test": "1.61.1",
    "@types/node": "26.1.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.5.2",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.10",
    "postcss": "8.5.16",
    "tailwindcss": "3.4.17",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
